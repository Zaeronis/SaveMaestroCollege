# Copy to .env.local and fill in. VITE_ vars are inlined into the build and
# are client-visible — EmailJS's public key + IDs are publishable by design.
# In Vercel, add the same vars under Project > Settings > Environment Variables.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_MAINTAINER_EMAIL=record@your-domain.example
